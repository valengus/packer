{
  "variables": {
    "winrm_username": "Admin",
    "winrm_password": "password",
    "iso_url": "https://tb.rg-adguard.net/dl.php?go=b1fb62af",
    "iso_checksum": "sha1:9cbbb18b244511bf1d4c68a33fe6ee35d2eda2ae",
    "cloud_token": "{{env `CLOUD_TOKEN`}}"
  },
  "builders": [
    {
      "type": "vmware-iso",
      "iso_url": "{{user `iso_url`}}",
      "iso_checksum": "{{user `iso_checksum`}}",
      "vm_name": "windows11_{{timestamp}}",
      "communicator": "winrm",
      "winrm_use_ssl": false,
      "winrm_username": "{{user `winrm_username`}}",
      "winrm_password": "{{user `winrm_password`}}",
      "winrm_insecure": "true",
      "shutdown_command": "E:/packerShutdown.bat",
      "disk_size": 61440,
      "disk_type_id": 0,
      "cpus": 2,
      "memory": 4096,
      "network_adapter_type": "e1000e",
      "guest_os_type": "windows9-64",
      "disk_adapter_type": "pvscsi",
      "cd_files": [
        "scripts/*",
        "unattend/autounattend.xml",
        "drivers/vmware/*"
      ],
      "boot_wait": "10s",
      "format": "ova",
      "keep_registered": false,
      "skip_export": false
    },
    {
      "type": "virtualbox-iso",
      "iso_url": "{{user `iso_url`}}",
      "iso_checksum": "{{user `iso_checksum`}}",
      "vm_name": "windows11x64_{{timestamp}}",
      "guest_os_type": "Windows11_64",
      "guest_additions_mode": "disable",
      "communicator": "winrm",
      "winrm_use_ssl": false,
      "winrm_username": "{{user `winrm_username`}}",
      "winrm_password": "{{user `winrm_password`}}",
      "winrm_insecure": "true",
      "shutdown_command": "E:/packerShutdown.bat",
      "disk_size": 61440,
      "cpus": 2,
      "memory": 4096,
      "cd_files": [
        "scripts/*",
        "unattend/autounattend.xml"
      ],
      "post_shutdown_delay": "5m",
      "boot_wait": "10s",
      "format": "ova",
      "keep_registered": false,
      "skip_export": false
    },
    {
      "type": "qemu",
      "accelerator": "kvm",
      "cpus": "2",
      "memory": "4096",
      "disk_size": "61440",
      "cd_files": [
        "unattend/autounattend.xml",
        "scripts/*",
        "drivers/qemu/*"
      ],
      "disk_interface": "virtio",
      "disk_cache": "writeback",
      "disk_discard": "ignore",
      "format": "qcow2",
      "headless": false,
      "iso_url": "{{user `iso_url`}}",
      "iso_checksum": "{{user `iso_checksum`}}",
      "shutdown_command": "E:/packerShutdown.bat",
      "shutdown_timeout": "15m",
      "vm_name": "windows11x64_{{timestamp}}",
      "use_default_display": false,
      "communicator": "winrm",
      "winrm_use_ssl": false,
      "winrm_username": "{{user `winrm_username`}}",
      "winrm_password": "{{user `winrm_password`}}",
      "winrm_insecure": "true"
    }
  ],
  "provisioners": [
    { "type": "sleep", "duration": "2m" },
    { "type": "shell-local", "inline": ["env"] },
    { "type": "ansible", "playbook_file": "./ansible/main.yml", "user": "Admin", "use_proxy": false },
    { "type": "powershell", "inline": [ "Invoke-Expression ((New-Object System.Net.WebClient).DownloadString('https://community.chocolatey.org/install.ps1'))" ] },
    { "type": "file", "source": "unattend/unattend.xml", "destination": "C:/Windows/Temp/unattend.xml" }
  ],
  "post-processors": [
    [
      {
        "compression_level": 9,
        "type": "vagrant",
        "vagrantfile_template": "vagrant/windows11.template",
        "output": "windows11-pro-{{.Provider}}.box"
      },
      {
        "type": "vagrant-cloud",
        "box_tag": "valengus/windows11-pro",
        "access_token": "{{user `cloud_token`}}",
        "version": "1.0.{{timestamp}}"
      }
    ]
  ]
}